# ── HealthPredict AI — ML Microservice Environment Variables ──
# Copy to .env for local dev, set in Render Dashboard for production

PORT=5001

# OpenAI API key (for GPT-4o vision OCR and chat)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# MongoDB URI (for appointments, family health, timeline data)
DB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/healthpredict?retryWrites=true&w=majority

# JWT secret (must match backend-node)
JWT_SECRET=your-super-secret-jwt-key-here
