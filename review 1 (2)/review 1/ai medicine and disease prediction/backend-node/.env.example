# ── HealthPredict AI — Node.js Backend Environment Variables ──
# Copy to .env for local dev, set in Render Dashboard for production

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
DB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/healthpredict?retryWrites=true&w=majority

# JWT signing secret (generate: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-here

# OpenAI API key
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# Flask ML service URL (for proxying requests)
ML_SERVICE_URL=https://healthpredict-ml.onrender.com

# Comma-separated list of allowed CORS origins (set your actual Vercel URL here)
ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.your-app.vercel.app
