# ── HealthPredict AI — Frontend Environment Variables ──────────────────────
# Local dev: copy to .env.local
# Production: set these in the Vercel Dashboard → Project → Settings → Environment Variables

# Node.js backend URL (Render)
VITE_API_URL=https://healthpredict-ai-etz5.onrender.com

# Flask ML microservice URL (Render)
VITE_ML_URL=https://healthpredict-ai-etz5.onrender.com

# Google Gemini API key (for HealthAssistant chatbot)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
